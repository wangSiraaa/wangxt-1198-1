{
  "name": "vault-cashbox-system",
  "version": "1.0.0",
  "description": "银行金库尾箱寄库交接系统",
  "main": "server/app.js",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev:server": "cd server && node app.js",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "start": "cd server && node app.js",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "dayjs": "^1.11.10"
  }
}
